{
  "manifest_version": 3,
  "name": "Cognitive Load Meter",
  "version": "1.0.0",
  "action": { "default_popup": "index.html" },
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ]
}